APP_NAME=EnergyPredict MLOps API
ENVIRONMENT=prod
API_V1_PREFIX=/api/v1
LOG_LEVEL=DEBUG
CORS_ALLOWED_ORIGINS=https://replace-me-static-web-app.azurestaticapps.net
HOST=0.0.0.0
PORT=8000
WORKERS=1
RELOAD=false

# Security placeholders (never use real secrets in repo)
JWT_SECRET_KEY=change-me-dev-only
FERNET_KEY=change-me-dev-only

# App integrations placeholders (AKS runtime should source from Key Vault)
DATABASE_URL=postgresql+psycopg2://replace-me
MLFLOW_TRACKING_URI=local://artifacts/mlflow
MLFLOW_REGISTRY_URI=
MLFLOW_EXPERIMENT_NAME=energypredict-training
MLFLOW_MODEL_NAME=asset_failure_classifier
MLFLOW_REGISTER_MODEL=false
MLFLOW_UC_CATALOG=
MLFLOW_UC_SCHEMA=
MLFLOW_REGISTERED_MODEL_NAME=
MODEL_STAGE=production

# Databricks (optional real integration)
DATABRICKS_WORKSPACE_URL=
DATABRICKS_TOKEN=
DATABRICKS_JOB_ID=

# Snowflake (optional real integration)
SNOWFLAKE_ACCOUNT=
SNOWFLAKE_USER=
SNOWFLAKE_PASSWORD=
SNOWFLAKE_WAREHOUSE=
SNOWFLAKE_DATABASE=
SNOWFLAKE_SCHEMA=
SNOWFLAKE_ROLE=

# Docker image metadata (used by AKS pipelines/manifests)
IMAGE_REPOSITORY=energypredictacr.azurecr.io/energypredict-api
IMAGE_TAG=release
